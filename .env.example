# Perform Creative — environment variables
# Copy to .env and fill in values. Required for running pipelines.

# === Required for app + Iterate pipeline ===
DATABASE_URL=mysql://user:password@host:3306/dbname
JWT_SECRET=your-jwt-secret-min-32-chars

# Manus OAuth (if using)
VITE_APP_ID=
OAUTH_SERVER_URL=
OWNER_OPEN_ID=
OWNER_NAME=

# Gemini image generation (Iterate + Static pipelines)
GOOGLE_AI_API_KEY=

# Claude / Anthropic (briefs, analysis, scripts)
ANTHROPIC_API_KEY=

# Forge/LLM proxy (voice transcription, image gen — NOT storage)
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=
OPENAI_API_KEY=

# DigitalOcean Spaces (file storage for uploads)
DO_SPACES_KEY=
DO_SPACES_SECRET=
DO_SPACES_BUCKET=
DO_SPACES_REGION=syd1
DO_SPACES_ENDPOINT=https://syd1.digitaloceanspaces.com

# Foreplay (competitor ad sync)
FOREPLAY_API_KEY=

# ClickUp (push tasks)
CLICKUP_API_KEY=

# === Optional / pipeline-specific ===
# UGC Clone + Face Swap
ELEVENLABS_API_KEY=
MAGIC_HOUR_API_KEY=

# Static pipeline (Bannerbear compositing)
BANNERBEAR_API_KEY=

# Flux Pro (alternative image backend)
FLUX_PRO_API_KEY=

# Canva (dormant)
CANVA_CLIENT_ID=
CANVA_CLIENT_SECRET=

# Port (default 3000)
PORT=3000
